---
import Layout from '../layouts/Layout.astro';
---

<Layout title="boboring.club | happy music. low stimulus." description="purposeful screen time for toddlers. join the club for happy music, low stimulus visuals, and big emotions. anti-cocomelon.">
    <main class="max-w-[480px] w-full">
        <div class="text-[3.5rem] font-bold tracking-tight mb-2 text-off-white">
            bobo<span class="text-lavender">ring</span>
        </div>
        
        <div class="inline-block bg-soft-black text-lavender text-[0.8rem] py-1 px-3 rounded-full border border-charcoal mb-4 tracking-[1px]">
            official club member
        </div>
        
        <div class="text-[1.1rem] text-tagline-gray mb-12 leading-relaxed">
            happy music. low stimulus. big emotions.<br>
            purposeful screen time for toddlers.
        </div>

        <div class="flex flex-col gap-[15px]">
            <a href="https://www.youtube.com/@boboringclub" class="block bg-soft-black text-off-white no-underline p-[18px] rounded-2xl font-bold transition-all duration-300 ease-in-out border border-border-gray text-base hover:bg-lavender hover:text-charcoal hover:border-lavender hover:-translate-y-0.5" target="_blank">
                ▶ watch on youtube
            </a>

            <a href="https://linktr.ee/boboringclub" class="block bg-soft-black text-off-white no-underline p-[18px] rounded-2xl font-bold transition-all duration-300 ease-in-out border border-border-gray text-base hover:bg-lavender hover:text-charcoal hover:border-lavender hover:-translate-y-0.5" target="_blank">
                🎧 stream on music apps
            </a>

            <a href="https://members.boboring.club" class="block bg-soft-black text-off-white no-underline p-[18px] rounded-2xl font-bold transition-all duration-300 ease-in-out border border-border-gray text-base hover:bg-lavender hover:text-charcoal hover:border-lavender hover:-translate-y-0.5" target="_blank">
                ☁️ get free printables
            </a>

            <a href="https://instagram.com/boboringclub" class="block bg-soft-black text-off-white no-underline p-[18px] rounded-2xl font-bold transition-all duration-300 ease-in-out border border-border-gray text-base hover:bg-lavender hover:text-charcoal hover:border-lavender hover:-translate-y-0.5" target="_blank">
                📸 follow on instagram
            </a>
        </div>

        <footer class="mt-16 text-[0.8rem] text-footer-gray">
            &copy; 2025 gizipp studios.<br>
            welcome to the club.
        </footer>
    </main>
</Layout>